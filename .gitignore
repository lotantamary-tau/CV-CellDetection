# Conda / virtual environments
.venv/
env/
venv/

# Git worktrees (local working copies of feature branches; never committed)
.worktrees/

# Local-only docs (planning artifacts, etc. — never tracked, not part of project history)
docs/

# Caiman example data (installed separately; not project code)
caiman_data/

# Local data folder — track the folder structure, ignore actual data files
data/*
!data/README.md

# Data file types — never commit, regardless of location
*.tif
*.tiff
*.rar

# CNMF runtime outputs now live under data/results/ and are covered
# by the data/* rule above. No separate ignore rules needed.

# Reference papers (not redistributed for copyright reasons)
research/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Jupyter
.ipynb_checkpoints/

# IDE
.idea/
.vscode/
*.swp

# OS
.DS_Store
Thumbs.db
