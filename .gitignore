data/*
!data/README.md

# Data file types — never commit, regardless of location
*.tif
*.tiff
*.rar

# CNMF runtime outputs (produced by cnmf_runner.py / cnmf_viewer.py)
cnmf_debug_outputs/
cnmf_results/

# Reference papers (not redistributed for copyright reasons)
reserch/

