# Conda / virtual environments
.venv/
env/
venv/

# Git worktrees (local working copies of feature branches; never committed)
.worktrees/

# Local-only docs (planning artifacts, etc. — never tracked, not part of project history)
docs/

# Caiman example data (installed separately; not project code)
caiman_data/

# Local data folder — track the folder structure (subfolders kept alive via
# .gitkeep markers so a fresh clone gets the full layout), ignore actual data
# files. *.tif/*.tiff/*.rar rules below also apply within data/.
data/*
!data/README.md
!data/RawData/
!data/TaggedData/
!data/results/
data/RawData/*
!data/RawData/.gitkeep
data/TaggedData/*
!data/TaggedData/.gitkeep
data/results/*
!data/results/debug_outputs/
!data/results/hdf5/
data/results/debug_outputs/*
!data/results/debug_outputs/.gitkeep
data/results/hdf5/*
!data/results/hdf5/.gitkeep

# Data file types — never commit, regardless of location
*.tif
*.tiff
*.rar

# CNMF runtime outputs now live under data/results/ and are covered
# by the data/* rule above. No separate ignore rules needed.

# Reference papers (not redistributed for copyright reasons)
research/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Jupyter
.ipynb_checkpoints/

# IDE
.idea/
.vscode/
*.swp

# Claude Code runtime artifacts (scheduled-task locks etc.)
.claude/*.lock

# OS
.DS_Store
Thumbs.db
